{
  "headers": [
    {
      "source": "/((?!assets/).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/((?!assets|pricing|vite).*)", "destination": "/index.html" }
  ]
}
